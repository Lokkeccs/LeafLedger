{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run i18n:keys:check && npm run design:tokens:check && tsc -b && vite build",
    "i18n:keys:check": "node ../tools/check-i18n-duplicate-keys.cjs",
    "design:tokens:check": "node ../tools/check-design-tokens.cjs",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "gen:api": "openapi-typescript ../backend/openapi/leafledger-v1.json -o ./src/api/schema.d.ts",
    "check:page-budget": "node ../tools/check-page-budget.cjs --strict",
    "preview": "vite preview",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.25.0",
    "@azure/msal-react": "^3.0.19",
    "@microsoft/signalr": "^10.0.0",
    "@tanstack/react-query": "^5.101.2",
    "i18next": "^25.7.0",
    "openapi-fetch": "^0.13.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^16.3.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.56.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@redocly/openapi-core": "2.40.0"
  }
}
